generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model customer {
  id            Int            @id
  name          String
  email         String         @unique
  role          String
  metadata      Json           @default("{}")
  customer_info customer_info?
}

model customer_info {
  id       Int      @id
  email    String
  customer customer @relation(fields: [id], references: [id], onDelete: Cascade)
}
  